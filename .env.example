# ============================================================
# RupeePulse — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars-change-this

# MongoDB (Atlas or local)
MONGODB_URI=mongodb://localhost:27017/rupeepulse
# Or Atlas: mongodb+srv://user:pass@cluster.mongodb.net/rupeepulse

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# CoinGecko API (https://www.coingecko.com/api)
# Free tier: 10-50 calls/min — no key needed for demo
COINGECKO_API_KEY=

# Binance WebSocket (public, no key needed)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Optional: Redis for caching
REDIS_URL=redis://localhost:6379

# Optional: Email (for price alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password

# App Settings
NEXT_PUBLIC_APP_NAME=RupeePulse
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CURRENCY=INR
NEXT_PUBLIC_STARTING_BALANCE=1000000
